{
  "name": "@may-salguedo/auth-common",
  "version": "1.0.7",
  "description": "Common authentication modules for NestJS microservices (guards, strategies, JWT validation)",
  "license": "EPL-2.0",
  "packageManager": "pnpm@10.8.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaySalguedo/auth-common.git"
  },
  "bugs": {
    "url": "https://github.com/MaySalguedo/auth-common/issues"
  },
  "homepage": "https://github.com/MaySalguedo/auth-common#readme",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "nest build",
    "pack": "pnpm pack",
    "output": "node -e \"const f=require('fs').readdirSync('.').find(f=>f.endsWith('.tgz'));if(f)console.log(require('path').resolve(f));else process.exit(1);\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "compile": "run-s build pack output",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:no-spec": "eslint \"src/**/*.ts\" --fix --ignore-pattern \"*.spec.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "audit": "pnpm audit --audit-level=low",
    "audit:trivy": "trivy fs --severity UNKNOWN,LOW,MEDIUM,HIGH,CRITICAL --scanners vuln,misconfig,license --skip-dirs node_modules .",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/passport": "^11.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.6.0",
    "jest": "^30.0.0",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/index.(t|j)s"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@tokens/(.*)$": "<rootDir>/common/tokens/$1",
      "^@guards/(.*)$": "<rootDir>/core/guards/$1",
      "^@decorators/(.*)$": "<rootDir>/common/decorators/$1",
      "^@interfaces/(.*)$": "<rootDir>/common/interfaces/$1",
      "^@strategies/(.*)$": "<rootDir>/core/strategies/$1"
    }
  }
}
